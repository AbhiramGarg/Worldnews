// prisma/schema.prisma

// --- 1. Generator Block (Defines the Client) ---
generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

// --- 2. Datasource Block (Defines the Connection Type) ---
datasource db {
  provider = "postgresql"
}

// --- 3. Model Definition ---
model NewsArticle {
  apiId           BigInt    @id @unique
  title           String    @db.VarChar(500)
  text            String
  summary         String?
  url             String?   @db.VarChar(1000) 
  image           String?   @db.VarChar(1000) 
  video           String?   @db.VarChar(1000) 
  publishDate     DateTime  @map("publish_date")
  sourceCountry   String    @db.VarChar(3) @map("source_country")
  language        String    @db.VarChar(10)
  author          String?
  authors         String[]
  category        String    @db.VarChar(50) @default("general")
  createdAt       DateTime  @default(now())

  @@map("news_article")
}

model CountrySyncStatus {
  id            BigInt   @id @default(autoincrement())
  window        String   @db.VarChar(20)
  country       String   @db.VarChar(3)
  lastRunId     String?  @map("last_run_id") @db.VarChar(80)
  lastAttemptAt DateTime @map("last_attempt_at")
  lastSuccessAt DateTime? @map("last_success_at")
  lastOutcome   String   @map("last_outcome") @db.VarChar(40)
  lastHttpStatus Int?    @map("last_http_status")
  fetchedCount  Int      @default(0) @map("fetched_count")
  sanitizedCount Int     @default(0) @map("sanitized_count")
  attemptCount  Int      @default(0) @map("attempt_count")
  lastError     String?  @map("last_error")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([window, country], map: "country_sync_status_window_country_key")
  @@map("country_sync_status")
}